# =============================================================
# Bullenhaus — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================

# -------------------------------------------------------
# Database (Supabase PostgreSQL)
# -------------------------------------------------------
# Transaction pooler URL — used by the running app (port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL — used only for Prisma migrations (port 5432)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# -------------------------------------------------------
# JWT Secrets — generate with: openssl rand -hex 32
# -------------------------------------------------------
JWT_ACCESS_SECRET="change-me-generate-with-openssl-rand-hex-32"
JWT_REFRESH_SECRET="change-me-generate-with-openssl-rand-hex-32-different"

# Access token lifetime (e.g. 15m, 1h)
JWT_ACCESS_EXPIRES_IN="15m"

# Refresh token lifetime (e.g. 7d, 30d)
JWT_REFRESH_EXPIRES_IN="7d"

# -------------------------------------------------------
# Supabase
# -------------------------------------------------------
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key-here"

# SERVICE ROLE KEY — backend and worker only, NEVER in frontend
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key-here"

# -------------------------------------------------------
# Worker Service
# -------------------------------------------------------
# Generate with: openssl rand -hex 32
WORKER_API_KEY="change-me-generate-with-openssl-rand-hex-32"

# -------------------------------------------------------
# Webhook / Sync
# -------------------------------------------------------
# HMAC secret for CRM<->Trading webhook signing
# Generate with: openssl rand -hex 32
SYNC_WEBHOOK_SECRET="change-me-generate-with-openssl-rand-hex-32"

# -------------------------------------------------------
# Super Admin (used by create-super-admin script only)
# -------------------------------------------------------
SUPER_ADMIN_EMAIL="superadmin@yourdomain.com"
# Set a strong password — min 16 chars
SUPER_ADMIN_PASSWORD="change-me-strong-password-here"
SUPER_ADMIN_FIRST_NAME="Super"
SUPER_ADMIN_LAST_NAME="Admin"

# -------------------------------------------------------
# Optional: Redis (for JWT denylist / logout-all)
# If not set, falls back to DB-backed DenylistedToken table
# -------------------------------------------------------
# REDIS_URL="redis://localhost:6379"

# -------------------------------------------------------
# Optional: AI Features
# -------------------------------------------------------
# GEMINI_API_KEY="your-gemini-api-key-here"

# -------------------------------------------------------
# Server
# -------------------------------------------------------
NODE_ENV="development"
PORT="3000"

# Public URL of the deployed backend (no trailing slash)
APP_URL="http://localhost:3000"

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174"

# -------------------------------------------------------
# Frontend (Vite — must be prefixed with VITE_)
# These are the ONLY env vars that should go to frontend
# -------------------------------------------------------
VITE_API_URL="http://localhost:3000"

# Only if frontend uses Supabase client for file storage (NOT auth)
# VITE_SUPABASE_URL="https://[project-ref].supabase.co"
# VITE_SUPABASE_ANON_KEY="your-supabase-anon-key-here"

# NEVER add VITE_SUPABASE_SERVICE_ROLE_KEY — service role must NOT be in frontend
