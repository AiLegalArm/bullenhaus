{
  "name": "bullenhaus",
  "version": "1.0.0",
  "description": "Bullenhaus — Unified CRM + Trading Platform",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "lint": "tsc --noEmit && eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:smoke": "tsx scripts/smoke-test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed-unified-roles.ts",
    "db:seed:crm": "tsx prisma/seed-crm-staff.ts",
    "db:verify": "tsx scripts/verify-migration.ts",
    "admin:create": "tsx scripts/create-super-admin.ts",
    "worker:start": "tsx src/server/workers/job.worker.ts",
    "rls:apply": "psql $DIRECT_URL -f supabase/migrations/003_rls_domain_isolation.sql",
    "vercel:env": "bash scripts/vercel-env-push.sh",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "^5.14.0",
    "@supabase/supabase-js": "^2.43.4",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.11",
    "@vercel/node": "^5.8.2",
    "@vitejs/plugin-react": "^5.0.4",
    "argon2": "^0.40.3",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "date-fns": "^4.2.1",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "framer-motion": "^12.38.0",
    "helmet": "^7.1.0",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "otpauth": "^9.3.4",
    "prisma": "^6.4.1",
    "qrcode": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "react-i18next": "^17.0.8",
    "react-is": "^19.0.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "zod": "^3.23.8",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "postcss": "^8.4.38",
    "prisma": "^5.14.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  }
}
